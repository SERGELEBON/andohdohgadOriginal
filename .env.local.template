# ========================================
# 1. SUPABASE (ESSENTIEL) ✅
# ========================================
#
# Où trouver ces clés ?
# 1. Allez sur https://supabase.com
# 2. Ouvrez votre projet : tszsvbzfufglvdcsjzpo
# 3. Settings → API
#
# Documentation : https://supabase.com/docs/guides/api

# URL du projet Supabase (déjà configuré)
VITE_SUPABASE_URL=https://tszsvbzfufglvdcsjzpo.supabase.co

# Clé publique (anon/public)
# Visible dans le frontend, utilisée pour les requêtes publiques
# Format : eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=REMPLACER_PAR_VOTRE_ANON_KEY

# Clé privée (service_role)
# NE PAS exposer dans le frontend, utilisée côté serveur
# Format : eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=REMPLACER_PAR_VOTRE_SERVICE_ROLE_KEY

# Mot de passe de la base de données (si nécessaire)
SUPABASE_DB_PASSWORD=Proud@#2026-


# ========================================
# 2. EMAILJS (ESSENTIEL) ✅
# ========================================
#
# Où trouver ces clés ?
# 1. Allez sur https://www.emailjs.com
# 2. Créez un compte gratuit (300 emails/mois)
# 3. Créez un service email et un template
#
# Documentation : https://www.emailjs.com/docs/

# ID du service email (ex: service_xyz123)
VITE_EMAILJS_SERVICE_ID=REMPLACER_PAR_VOTRE_SERVICE_ID

# ID du template (ex: template_abc456)
VITE_EMAILJS_TEMPLATE_ID=REMPLACER_PAR_VOTRE_TEMPLATE_ID

# Clé publique (ex: user_def789)
VITE_EMAILJS_PUBLIC_KEY=REMPLACER_PAR_VOTRE_PUBLIC_KEY


# ========================================
# 3. STRIPE (IMPORTANT) ⚠️
# ========================================
#
# Où trouver ces clés ?
# 1. Allez sur https://stripe.com
# 2. Developers → API keys
# 3. Basculez en mode "Test" (en haut à droite)
#
# Documentation : https://stripe.com/docs/keys

# Clé publique (pk_test_... en mode test)
# Visible dans le frontend
VITE_STRIPE_PUBLIC_KEY=REMPLACER_PAR_pk_test_VOTRE_CLE_PUBLIQUE

# Clé secrète (sk_test_... en mode test)
# NE PAS exposer dans le frontend
STRIPE_SECRET_KEY=REMPLACER_PAR_sk_test_VOTRE_CLE_SECRETE

# Secret du webhook (pour les notifications de paiement)
# Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=REMPLACER_PAR_whsec_VOTRE_WEBHOOK_SECRET


# ========================================
# 4. reCAPTCHA (IMPORTANT) ⚠️
# ========================================
#
# Où trouver ces clés ?
# 1. Allez sur https://www.google.com/recaptcha/admin
# 2. Créez un site avec reCAPTCHA v2
# 3. Ajoutez localhost dans les domaines autorisés
#
# Documentation : https://developers.google.com/recaptcha

# Clé publique (Site Key)
# Visible dans le frontend
VITE_RECAPTCHA_SITE_KEY=REMPLACER_PAR_VOTRE_SITE_KEY

# Clé secrète (Secret Key)
# NE PAS exposer dans le frontend
RECAPTCHA_SECRET_KEY=REMPLACER_PAR_VOTRE_SECRET_KEY


# ========================================
# 5. ORANGE MONEY (OPTIONNEL) 📦
# ========================================
#
# Où trouver ces clés ?
# 1. Allez sur https://developer.orange.com
# 2. Créez un compte développeur
# 3. Créez une application et souscrivez à Orange Money API
#
# Documentation : https://developer.orange.com/apis/orange-money-webpay/

# URL de l'API (Sandbox par défaut)
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/

# Consumer Key (Merchant Key)
ORANGE_MONEY_MERCHANT_KEY=REMPLACER_PAR_VOTRE_MERCHANT_KEY

# Consumer Secret (API Key)
ORANGE_MONEY_API_KEY=REMPLACER_PAR_VOTRE_API_KEY


# ========================================
# 6. MTN MOBILE MONEY (OPTIONNEL) 📦
# ========================================
#
# Où trouver ces clés ?
# 1. Allez sur https://momodeveloper.mtn.com
# 2. Créez un compte développeur
# 3. Souscrivez à l'API Collection
# 4. Créez un API User et une API Key
#
# Documentation : https://momodeveloper.mtn.com/api-documentation

# URL de l'API (Sandbox par défaut)
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com/

# Subscription Key (Ocp-Apim-Subscription-Key)
MTN_MOMO_SUBSCRIPTION_KEY=REMPLACER_PAR_VOTRE_SUBSCRIPTION_KEY

# API User ID (créé via POST /v1_0/apiuser)
MTN_MOMO_API_USER=REMPLACER_PAR_VOTRE_API_USER_ID

# API Key (créé via POST /v1_0/apiuser/{userId}/apikey)
MTN_MOMO_API_KEY=REMPLACER_PAR_VOTRE_API_KEY


